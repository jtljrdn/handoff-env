# Production env template. Copy to /srv/handoff-env/shared/.env on the VPS,
# fill in real values, chmod 600, chown deploy:deploy.

NODE_ENV=production

# --- App ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://app.yourdomain.com
BETTER_AUTH_TRUSTED_ORIGINS=https://www.yourdomain.com,https://app.yourdomain.com

# --- Supabase Postgres (use the POOLED connection, port 6543) ---
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# --- Supabase APIs ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- OAuth providers (if any) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
