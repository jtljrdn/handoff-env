# Production env template. Copy to /srv/handoff-env/shared/.env on the VPS,
# fill in real values, chmod 600, chown deploy:deploy.

NODE_ENV=production

# --- App ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://www.yourdomain.com
BETTER_AUTH_TRUSTED_ORIGINS=https://www.yourdomain.com

# --- Supabase Postgres (use the POOLED connection, port 6543) ---
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# --- Supabase ---
VITE_SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Publishable key is client-side, so it needs the VITE_ prefix.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- OAuth providers (if any) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=