{
	email jordan@jtlee.dev
}

(app_upstream) {
	reverse_proxy {
		to 127.0.0.1:3001 127.0.0.1:3002
		lb_policy first
		health_uri /api/healthz
		health_interval 5s
		health_timeout 2s
		fail_duration 10s
	}
}

# Client build served directly from disk on both hosts.
(static_assets) {
	handle_path /assets/* {
		root * /srv/handoff-env/current/apps/web/dist/client/assets
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	@static_root path /favicon.ico /robots.txt /manifest.json /logo192.png /logo512.png /drizzle.svg
	handle @static_root {
		root * /srv/handoff-env/current/apps/web/dist/client
		file_server
	}
}

# Apex -> www
gethandoff.dev {
	redir https://www.gethandoff.dev{uri} 301
}

# Marketing host: only / and /pricing live here. Everything else redirects to app.
www.gethandoff.dev {
	encode zstd gzip

	import static_assets

	@marketing_pages path / /pricing
	handle @marketing_pages {
		import app_upstream
	}

	handle {
		redir https://app.gethandoff.dev{uri} 301
	}
}

# Product host: everything except /pricing. Root redirects to /dashboard.
app.gethandoff.dev {
	encode zstd gzip

	import static_assets

	@root path /
	handle @root {
		redir https://app.gethandoff.dev/dashboard 302
	}

	@pricing path /pricing
	handle @pricing {
		redir https://www.gethandoff.dev/pricing 301
	}

	handle {
		import app_upstream
	}
}
