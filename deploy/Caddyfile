{
	email jordan@jtlee.dev
}

(app_upstream) {
	reverse_proxy {
		to 127.0.0.1:3001 127.0.0.1:3002
		lb_policy first
		health_uri /api/healthz
		health_interval 5s
		health_timeout 2s
		fail_duration 10s
	}
}

# Serve the client build directly from disk. Faster than proxying through Bun,
# and works regardless of how the app's server.js resolves static paths.
(static_assets) {
	handle_path /assets/* {
		root * /srv/handoff-env/current/apps/web/dist/client/assets
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	@static_root path /favicon.ico /robots.txt /manifest.json /logo192.png /logo512.png /drizzle.svg
	handle @static_root {
		root * /srv/handoff-env/current/apps/web/dist/client
		file_server
	}
}

# Apex -> www
gethandoff.dev {
	redir https://www.gethandoff.dev{uri} 301
}

# Marketing host
www.gethandoff.dev {
	encode zstd gzip

	import static_assets

	# Product paths belong on app.
	@product_paths path /dashboard /dashboard/* /billing /billing/* /projects /projects/* /onboarding /onboarding/* /invite/*
	handle @product_paths {
		redir https://app.gethandoff.dev{uri} 301
	}

	# Everything else (marketing pages, sign-in/up, /api/*) goes to the app
	handle {
		import app_upstream
	}
}

# Product host
app.gethandoff.dev {
	encode zstd gzip

	import static_assets

	# Bare root -> dashboard
	@root path /
	handle @root {
		redir https://app.gethandoff.dev/dashboard 302
	}

	handle {
		import app_upstream
	}
}
