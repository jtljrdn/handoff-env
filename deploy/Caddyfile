{
	email jordan@jtlee.dev
}

(app_upstream) {
	reverse_proxy {
		to 127.0.0.1:3001 127.0.0.1:3002
		lb_policy first
		health_uri /api/healthz
		health_interval 5s
		health_timeout 2s
		fail_duration 10s
	}
}

# Apex -> www
gethandoff.dev {
	redir https://www.gethandoff.dev{uri} 301
}

# Marketing host
www.gethandoff.dev {
	encode zstd gzip

	@assets path /assets/* /favicon.ico /robots.txt /manifest.json /logo*.png /drizzle.svg
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Product paths belong on app. — redirect the user there.
	# Everything else (marketing pages + any asset/runtime path the app uses)
	# is proxied to the upstream so the page renders correctly.
	@product_paths path /dashboard /dashboard/* /billing /billing/* /projects /projects/* /onboarding /onboarding/* /invite/*
	handle @product_paths {
		redir https://app.gethandoff.dev{uri} 301
	}

	handle {
		import app_upstream
	}
}

# Product host
app.gethandoff.dev {
	encode zstd gzip

	@assets path /assets/* /favicon.ico /robots.txt /manifest.json /logo*.png /drizzle.svg
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Bare root on app. -> dashboard
	@root path /
	redir @root https://app.gethandoff.dev/dashboard 302

	import app_upstream
}
