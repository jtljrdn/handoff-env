{
	email jordan@jtlee.dev
}

(app_upstream) {
	reverse_proxy {
		to 127.0.0.1:3001 127.0.0.1:3002
		lb_policy first
		health_uri /api/healthz
		health_interval 5s
		health_timeout 2s
		fail_duration 10s
	}
}

# Apex and app. -> www. Use 308 so POST bodies (API calls that hit the apex) are preserved.
gethandoff.dev, app.gethandoff.dev {
	redir https://www.gethandoff.dev{uri} 308
}

www.gethandoff.dev {
	encode zstd gzip

	handle_path /assets/* {
		root * /srv/handoff-env/current/apps/web/dist/client/assets
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	handle_path /images/* {
		root * /srv/handoff-env/current/apps/web/dist/client/images
		file_server
	}

	@static_root path /favicon.ico /robots.txt /manifest.json /logo192.png /logo512.png /drizzle.svg
	handle @static_root {
		root * /srv/handoff-env/current/apps/web/dist/client
		file_server
	}

	handle {
		import app_upstream
	}
}
